# BTDeck 后端环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改配置

# ================================
# 应用基础配置
# ================================
PROJECT_NAME=btdeck

# ================================
# 数据库配置
# ================================
# SQLite 数据库文件名（相对于 config/ 目录）
DATABASE_NAME=app.db

# ================================
# 安全配置
# ================================
# JWT 密钥（生产环境务必修改为随机字符串）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=YM4nwx3QBbZ227i5itqf

# 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=600

# JWT 算法（默认 HS256，不建议修改）
ALGORITHM=HS256

# ================================
# 服务器配置
# ================================
# API 服务端口（默认 5001）
# API_PORT=5001

# WebSocket 服务端口（默认 5002）
# WS_PORT=5002

# ================================
# 日志配置
# ================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# ================================
# 开发模式配置
# ================================
# 开发环境: true
# 生产环境: false
# DEBUG=false
