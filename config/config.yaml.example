# BTDeck 配置文件模板
# 复制为 config.yaml 并填入实际值，切勿将 config.yaml 提交到版本控制
# 密钥生成: python -c "import secrets; print(secrets.token_hex(16))"

app:
  name: BtDeck
  version: 1.0.4
  debug: false
  log_level: INFO
database:
  host: localhost
  port: 3306
  username: user
  password: password
  database: mydb
  charset: utf8mb4
  pool_size: 5
server:
  host: 0.0.0.0
  port: 8000
  workers: 4
  timeout: 60
security:
  secret_key: your-secret-key-here
  token_expire_minutes: 60
  algorithm: HS256
  login_status_secret: your-login-secret-here
cors:
  allowed_origins:
  - '*'
  allowed_methods:
  - '*'
  allowed_headers:
  - '*'
logging:
  file: app.log
  max_size_mb: 10
  backup_count: 5
